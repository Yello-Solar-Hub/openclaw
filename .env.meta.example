# ============================================================================
# OpenClaw Meta Platforms Configuration Template
# ============================================================================
# IMPORTANTE: Este arquivo é um TEMPLATE com placeholders.
# NUNCA commit credenciais reais aqui ou em .env.meta
# 
# Para usar:
# 1. Copie este arquivo: cp .env.meta.example ~/.openclaw/.env.meta
# 2. Edite ~/.openclaw/.env.meta com suas credenciais REAIS
# 3. Certifique-se de que ~/.openclaw está em .gitignore
#
# Documentação: docs/channels/meta-config.md
# ============================================================================

# ========== Meta App Credentials (Compartilhado) ==========
# Obtenha em: https://developers.facebook.com/apps/
# Cada app Meta tem um único APP_ID e APP_SECRET
META_APP_ID="<seu-app-id-aqui>"
META_APP_SECRET="<seu-app-secret-aqui>"

# ========== WhatsApp (Baileys — QR Code) ==========
# Status: ✅ PRODUÇÃO
# Método: WhatsApp Web via Baileys
# Credenciais: Armazenadas automaticamente em ~/.openclaw/credentials/whatsapp/
# Não requer setup manual aqui
# WHATSAPP_SESSION_DIR="${HOME}/.openclaw/credentials/whatsapp"

# ========== Facebook Messenger API (⏳ Em Desenvolvimento) ==========
# Status: Código pronto, testes em progresso
# Obtenha em: https://developers.facebook.com/docs/messenger-platform
#
# 1. Página ID: https://developers.facebook.com/docs/messenger-platform/getting-started#page_access_token
#    curl -i -X GET "https://graph.facebook.com/{page-id}?access_token={token}"
# 2. Page Access Token: gerado no App Dashboard → Messenger → Token de Acesso à Página
# 3. Verify Token: qualquer string única que você criar para validar webhooks
MESSENGER_PAGE_ID="<sua-facebook-page-id>"
MESSENGER_PAGE_ACCESS_TOKEN="<sua-page-access-token>"
MESSENGER_VERIFY_TOKEN="<seu-verify-token-unico-para-webhook>"

# ========== Instagram DM API (⏳ Em Desenvolvimento) ==========
# Status: Código pronto, testes em progresso
# Pré-requisito: Conta Instagram Business ou Creator vinculada à Página Facebook
# Obtenha em: https://developers.facebook.com/docs/instagram-graph-api
#
# 1. Business Account ID:
#    curl -X GET "https://graph.facebook.com/v21.0/{page-id}?fields=instagram_business_account&access_token={token}"
# 2. Access Token: use o mesmo token da Página (com permissão instagram_basic)
# 3. Verify Token: qualquer string única (pode ser igual a MESSENGER_VERIFY_TOKEN)
INSTAGRAM_BUSINESS_ACCOUNT_ID="<seu-instagram-business-id>"
INSTAGRAM_ACCESS_TOKEN="<sua-instagram-access-token>"
INSTAGRAM_VERIFY_TOKEN="<seu-verify-token-unico-para-webhook>"

# ========== Threads API (⏳ Em Desenvolvimento) ==========
# Status: Código pronto, testes em progresso
# Obtenha em: https://developers.facebook.com/docs/threads
#
# 1. User ID: curl -X GET "https://graph.threads.net/v1.0/me?access_token={token}" → id
# 2. Access Token: token gerado com escopo threads_basic
# 3. Verify Token: qualquer string única para validação de webhook
THREADS_USER_ID="<seu-threads-user-id>"
THREADS_ACCESS_TOKEN="<seu-threads-access-token>"
THREADS_VERIFY_TOKEN="<seu-verify-token-unico-para-webhook>"

# ========== Webhook Comum (Futuro) ==========
# Quando Messenger, Instagram, Threads estiverem em produção:
# Todos os webhooks irão para a mesma URL com paths diferentes:
# - /webhooks/messenger
# - /webhooks/instagram
# - /webhooks/threads
# Este token é compartilhado com META_APP_SECRET para validação HMAC
META_WEBHOOK_CALLBACK_URL="https://<seu-dominio>.com/webhooks/meta"

# ========== Segurança & Governança ==========
# Essas variáveis nunca devem ser commitadas em git
# Armazenar em: ~/.openclaw/.env.meta (ignorado por .gitignore)
# 
# ⚠️  Se você acidentalmente commitar credenciais:
# 1. Revogue imediatamente em https://developers.facebook.com/apps/
# 2. Gere novos tokens
# 3. Force-push para remover do histórico: git filter-branch --tree-filter
#
# Para rotacionar segredos:
# - WhatsApp: Rescan QR code (logout e re-login)
# - Messenger/Instagram/Threads: Regenere tokens no App Dashboard
