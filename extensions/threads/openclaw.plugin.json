{
  "$schema": "https://openclaw.ai/schema/openclaw-plugin.v1.json",
  "id": "threads",
  "name": "Threads",
  "version": "0.1.0",
  "description": "Meta Threads API channel support for OpenClaw",
  "author": "OpenClaw Team",
  "license": "MIT",
  "configSchema": {
    "type": "object",
    "properties": {
      "accounts": {
        "type": "object",
        "additionalProperties": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": true },
            "threadsUserId": { "type": "string" },
            "accessToken": { "type": "string", "sensitive": true },
            "appSecret": { "type": "string", "sensitive": true },
            "verifyToken": { "type": "string", "sensitive": true },
            "webhookPath": { "type": "string", "default": "/webhooks/threads" },
            "defaultReplyControl": { "type": "string", "enum": ["everyone", "mentioned", "none"], "default": "everyone" }
          },
          "required": ["threadsUserId", "accessToken", "appSecret", "verifyToken"]
        }
      }
    },
    "required": ["accounts"]
  },
  "channel": {
    "id": "threads",
    "label": "Threads",
    "selectionLabel": "Threads by Instagram",
    "detailLabel": "Threads API",
    "docsPath": "/channels/threads",
    "blurb": "Engage on Meta Threads",
    "systemImage": "thread",
    "markdownCapable": true
  },
  "install": {
    "npmSpec": "@openclaw/threads",
    "localPath": "extensions/threads",
    "defaultChoice": "npm",
    "minHostVersion": ">=2026.3.28"
  },
  "openclaw": {
    "minVersion": "2026.3.28"
  }
}
