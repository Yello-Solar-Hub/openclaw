{
  "name": "@openclaw/threads",
  "version": "0.1.0",
  "private": true,
  "description": "Threads API channel plugin for OpenClaw",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./runtime-api": {
      "types": "./dist/runtime-api.d.ts",
      "import": "./dist/runtime-api.js",
      "default": "./dist/runtime-api.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "oxlint src test",
    "format": "oxfmt src test"
  },
  "dependencies": {
    "@openclaw/meta-common": "workspace:*",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "openclaw": "workspace:*",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  },
  "openclaw": {
    "bundle": {
      "stageRuntimeDependencies": false
    },
    "extensions": [
      "./src/index.ts"
    ],
    "setupEntry": "./src/setup-entry.ts"
  }
}
