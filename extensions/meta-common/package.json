{
  "name": "@openclaw/meta-common",
  "version": "0.1.0",
  "private": true,
  "description": "Shared utilities for Meta Platform plugins (Facebook, Instagram, Threads)",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.js",
      "default": "./dist/auth/index.js"
    },
    "./http": {
      "types": "./dist/http/index.d.ts",
      "import": "./dist/http/index.js",
      "default": "./dist/http/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js",
      "default": "./dist/types/index.js"
    },
    "./webhook": {
      "types": "./dist/webhook/index.d.ts",
      "import": "./dist/webhook/index.js",
      "default": "./dist/webhook/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "oxlint src test",
    "format": "oxfmt src test"
  },
  "dependencies": {
    "axios": "^1.8.2",
    "jose": "^6.0.10",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "openclaw": "workspace:*",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  },
  "openclaw": {
    "bundle": {
      "stageRuntimeDependencies": false
    }
  }
}
